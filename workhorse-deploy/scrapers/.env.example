# Copy to /srv/scrapers/.env on the Mac (file is gitignored)

# Database
DB_HOST=localhost
DB_PORT=5433
DB_NAME=workhorse
DB_USER=workhorse_user
DB_PASSWORD=REPLACE_WITH_YOUR_DB_PASSWORD

# Perplexity
PERPLEXITY_API_KEY=pplx-REPLACE_WITH_YOUR_KEY

# Gmail (use a Google App Password, NOT your account password)
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=REPLACE_WITH_GOOGLE_APP_PASSWORD

# SMTP for sending the weekly digest
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=REPLACE_WITH_APP_PASSWORD
SMTP_FROM=your_email@gmail.com
DIGEST_RECIPIENT=your_email@gmail.com

# Storage
USB_ROOT=/mnt/usb-archive

# Optional API keys
COMPANIES_HOUSE_API_KEY=
